{
  "name": "vlogging",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:clean": "docker exec vlogging-postgres-1 psql -U vlog -d postgres -c 'DROP DATABASE IF EXISTS auth_db' -c 'DROP DATABASE IF EXISTS user_db' -c 'DROP DATABASE IF EXISTS blog_db' -c 'DROP DATABASE IF EXISTS comment_db' && docker exec vlogging-postgres-1 psql -U vlog -d postgres -c 'CREATE DATABASE auth_db' -c 'CREATE DATABASE user_db' -c 'CREATE DATABASE blog_db' -c 'CREATE DATABASE comment_db'",
    "build:all": "nest build api-gateway && nest build auth-service && nest build user-service && nest build blog-service && nest build comment-service && nest build email-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start api-gateway",
    "start:dev": "nest start api-gateway --webpack --watch",
    "start:auth": "nest start auth-service --webpack --watch",
    "start:user": "nest start user-service --webpack --watch",
    "start:blog": "nest start blog-service --webpack --watch",
    "start:comment": "nest start comment-service --webpack --watch",
    "start:email": "nest start email-service --webpack --watch",
    "dev": "docker compose up -d postgres redis && concurrently --names \"auth,user,blog,comment,email,gateway\" --prefix-colors \"blue,green,yellow,magenta,red,cyan\" \"pnpm start:auth\" \"pnpm start:user\" \"pnpm start:blog\" \"pnpm start:comment\" \"pnpm start:email\" \"pnpm start:dev\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json",
    "load-test:build": "node load-test/build.mjs",
    "load-test:smoke": "pnpm load-test:build && k6 run load-test/dist/smoke.js",
    "load-test:stress": "pnpm load-test:build && k6 run load-test/dist/stress.js",
    "load-test:auth": "pnpm load-test:build && k6 run load-test/dist/auth-flow.js",
    "load-test:smoke:uat": "pnpm load-test:build && k6 run --env ENV=uat load-test/dist/smoke.js",
    "load-test:stress:uat": "pnpm load-test:build && k6 run --env ENV=uat load-test/dist/stress.js",
    "load-test:auth:uat": "pnpm load-test:build && k6 run --env ENV=uat load-test/dist/auth-flow.js",
    "docker:build": "DOCKER_USER=${DOCKER_USER:-sarthak8317} TAG=${TAG:-uat} node scripts/docker-build.mjs",
    "docker:push": "DOCKER_USER=${DOCKER_USER:-sarthak8317} TAG=${TAG:-uat} node scripts/docker-push.mjs"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/instrumentation-express": "^0.64.0",
    "@opentelemetry/instrumentation-grpc": "^0.216.0",
    "@opentelemetry/instrumentation-http": "^0.216.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.62.0",
    "@opentelemetry/instrumentation-pg": "^0.68.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/bcryptjs": "^3.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/k6": "^1.7.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@app/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@app/common": "<rootDir>/libs/common/src"
    }
  }
}
